# OpenAI API Key
# IMPORTANT: Never commit this file to version control
# Use a secure method to manage and distribute secrets in production
OPENAI_API_KEY=your-api-key-goes-here
# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=0

# Database configuration
DATABASE_URL=sqlite:///clientecho.db

# File upload configuration
MAX_CONTENT_LENGTH=104857600  # 100 MB in bytes
UPLOAD_FOLDER=/path/to/secure_uploads  # Use an absolute path outside the web root